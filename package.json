{
  "name": "watchlist-backend",
  "version": "1.0.0",
  "description": "Backend API for WatchList app - Node.js + TypeScript + Express + Supabase",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "echo \"Tests not yet configured\" && exit 0",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "watchlist",
    "justwatch",
    "tmdb",
    "streaming",
    "expo"
  ],
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.0",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "node-cache": "^5.1.2",
    "winston": "^3.17.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^8.57.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3"
  }
}
